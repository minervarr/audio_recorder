<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <LinearLayout
            android:id="@+id/device_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_device_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/green_bright"
                android:textSize="18sp"
                android:text="@string/no_device" />

            <TextView
                android:id="@+id/device_format_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/device_tap_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/green_bright"
                android:textSize="13sp"
                android:text="@string/device_tap_to_grant"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sample_rate_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:textColor="@color/green_bright"
                app:strokeColor="@color/green_primary"
                android:text="@string/format_sample_rate" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/bit_depth_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:textColor="@color/green_bright"
                app:strokeColor="@color/green_primary"
                android:text="@string/format_bit_depth" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/channels_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:enabled="false"
                android:textColor="@color/green_bright"
                app:strokeColor="@color/green_primary"
                android:text="@string/format_channels" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/monitor_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_primary"
            android:thumbTint="@color/green_bright"
            android:trackTint="@color/green_dim"
            android:text="@string/monitor_label" />

        <LinearLayout
            android:id="@+id/monitor_volume_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <SeekBar
                android:id="@+id/monitor_volume_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:max="1000"
                android:progress="500"
                android:progressDrawable="@drawable/seekbar_progress"
                android:thumb="@drawable/seekbar_thumb"
                android:splitTrack="false" />

            <TextView
                android:id="@+id/monitor_volume_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="56dp"
                android:gravity="end"
                android:textColor="@color/green_bright"
                android:textSize="13sp"
                android:text="@string/volume_muted" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/record_button"
            android:layout_width="160dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:enabled="false"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:text="@string/record_start"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="32dp"
            app:icon="@drawable/ic_record"
            app:iconTint="@color/black" />

        <TextView
            android:id="@+id/elapsed_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/green_bright"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/recordings_header"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/recordings_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/recordings_empty"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recordings_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
