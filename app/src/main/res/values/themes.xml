<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AudioRecorder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dim</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/green_bright</item>
        <item name="colorSecondaryVariant">@color/green_dim</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:fontFamily">@font/cmu_serif</item>
        <item name="fontFamily">@font/cmu_serif</item>
        <item name="tabStyle">@style/Widget.AudioRecorder.Tab</item>
    </style>

    <style name="Widget.AudioRecorder.Tab" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicator">@drawable/bg_tab_indicator</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabRippleColor">@color/green_muted</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/green_bright</item>
    </style>

    <style name="RoundedCorner6" parent="">
        <item name="cornerSize">6dp</item>
    </style>

    <style name="RoundedCorner4" parent="">
        <item name="cornerSize">4dp</item>
    </style>

    <style name="Theme.AudioRecorder.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/bg_elevated</item>
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorSecondary">@color/green_bright</item>
        <item name="android:fontFamily">@font/cmu_serif</item>
        <item name="fontFamily">@font/cmu_serif</item>
    </style>
</resources>
